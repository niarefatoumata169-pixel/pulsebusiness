import express from 'express';
import cors from 'cors';
import helmet from 'helmet';
import morgan from 'morgan';
import dotenv from 'dotenv';
import { Pool } from 'pg';

// Routes
import authRoutes from './routes/auth.routes';
import clientRoutes from './routes/client.routes';
import devisRoutes from './routes/devis.routes';
import factureRoutes from './routes/facture.routes';
import caisseRoutes from './routes/caisse.routes';

// Middleware
import { authMiddleware } from './middleware/auth.middleware';

dotenv.config();

const app = express();
const PORT = process.env.PORT || 3001;

// Connexion PostgreSQL
export const pool = new Pool({
  host: process.env.DB_HOST || 'localhost',
  port: parseInt(process.env.DB_PORT || '5432'),
  database: process.env.DB_NAME || 'pulsebusiness',
  user: process.env.DB_USER || 'mac',
  password: process.env.DB_PASSWORD || '',
});

// Tester la connexion
pool.connect((err, client, release) => {
  if (err) {
    console.error('❌ Erreur de connexion à PostgreSQL:', err.message);
  } else {
    console.log('✅ Connecté à PostgreSQL avec succès !');
    release();
  }
});

// Middleware
app.use(helmet());
app.use(cors({
  origin: process.env.CLIENT_URL || 'http://localhost:4200',
  credentials: true
}));
app.use(morgan('dev'));
app.use(express.json());

// Routes publiques
app.use('/api/auth', authRoutes);

// Routes protégées (nécessitent un token)
app.use('/api/clients', authMiddleware, clientRoutes);
app.use('/api/devis', authMiddleware, devisRoutes);
app.use('/api/factures', authMiddleware, factureRoutes);
app.use('/api/caisses', authMiddleware, caisseRoutes);

// Route de test publique
app.get('/api/health', (req, res) => {
  res.json({ 
    status: 'OK', 
    message: 'Serveur PulseBusiness en ligne',
    database: pool ? 'connectée' : 'non connectée'
  });
});

// Route pour lister toutes les tables (protégée)
app.get('/api/test-db', authMiddleware, async (req, res) => {
  try {
    const result = await pool.query(`
      SELECT table_name 
      FROM information_schema.tables 
      WHERE table_schema = 'public'
    `);
    res.json({ 
      success: true, 
      tables: result.rows.map(row => row.table_name)
    });
  } catch (error) {
    const err = error as any;
    res.status(500).json({ success: false, error: err.message });
  }
});

// Gestion des erreurs
app.use((err: any, req: express.Request, res: express.Response, next: express.NextFunction) => {
  console.error(err.stack);
  res.status(500).json({ message: 'Erreur serveur', error: err.message });
});

app.listen(PORT, () => {
  console.log(`🚀 Serveur démarré sur http://localhost:${PORT}`);
  console.log(`📝 Routes disponibles:`);
  console.log(`   - POST /api/auth/register`);
  console.log(`   - POST /api/auth/login`);
  console.log(`   - GET  /api/auth/profile (protégée)`);
  console.log(`   - GET  /api/health`);
  console.log(`   - GET  /api/clients (protégée)`);
  console.log(`   - POST /api/clients (protégée)`);
  console.log(`   - GET  /api/devis (protégée)`);
  console.log(`   - POST /api/devis (protégée)`);
  console.log(`   - GET  /api/factures (protégée)`);
  console.log(`   - POST /api/factures (protégée)`);
  console.log(`   - GET  /api/caisses (protégée)`);
  console.log(`   - POST /api/caisses (protégée)`);
});

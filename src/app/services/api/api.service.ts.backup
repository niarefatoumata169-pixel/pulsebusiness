import { Injectable } from '@angular/core';
import { HttpClient, HttpHeaders } from '@angular/common/http';
import { lastValueFrom } from 'rxjs';
import { User, Client, Facture, Contrat, Devis } from '../../models/index';

export interface LoginResponse {
  user: User;
  token: string;
}

@Injectable({
  providedIn: 'root'
})
export class ApiService {
  public http: HttpClient;
  public apiUrl = 'http://localhost:3004/api';
  private tokenKey = 'auth_token';
  private userKey = 'user_data';

  constructor(http: HttpClient) {
    this.http = http;
    this.loadStoredUser();
  }

  // ==================== AUTHENTIFICATION ====================
  
  async login(email: string, password: string): Promise<User | null> {
    try {
      const response = await lastValueFrom(
        this.http.post<LoginResponse>(`${this.apiUrl}/auth/login`, { email, password })
      );
      
      if (response && response.token) {
        this.setToken(response.token);
        this.setUser(response.user);
        return response.user;
      }
      return null;
    } catch (error) {
      console.error('Erreur login:', error);
      return null;
    }
  }

  async register(userData: any): Promise<User | null> {
    try {
      const response = await lastValueFrom(
        this.http.post<LoginResponse>(`${this.apiUrl}/auth/register`, userData)
      );
      
      if (response && response.token) {
        this.setToken(response.token);
        this.setUser(response.user);
        return response.user;
      }
      return null;
    } catch (error) {
      console.error('Erreur register:', error);
      return null;
    }
  }

  logout(): void {
    localStorage.removeItem(this.tokenKey);
    localStorage.removeItem(this.userKey);
  }

  async getProfile(): Promise<User | null> {
    try {
      return await lastValueFrom(
        this.http.get<User>(`${this.apiUrl}/auth/profile`, {
          headers: this.getAuthHeaders()
        })
      );
    } catch (error) {
      console.error('Erreur getProfile:', error);
      return null;
    }
  }

  // ==================== CLIENTS ====================
  
  async getClients(): Promise<Client[]> {
    try {
      return await lastValueFrom(
        this.http.get<Client[]>(`${this.apiUrl}/clients`, {
          headers: this.getAuthHeaders()
        })
      ) || [];
    } catch (error) {
      console.error('Erreur getClients:', error);
      return [];
    }
  }

  async getClient(id: number): Promise<Client | null> {
    try {
      return await lastValueFrom(
        this.http.get<Client>(`${this.apiUrl}/clients/${id}`, {
          headers: this.getAuthHeaders()
        })
      );
    } catch (error) {
      console.error('Erreur getClient:', error);
      return null;
    }
  }

  async createClient(client: Partial<Client>): Promise<Client | null> {
    try {
      return await lastValueFrom(
        this.http.post<Client>(`${this.apiUrl}/clients`, client, {
          headers: this.getAuthHeaders()
        })
      );
    } catch (error) {
      console.error('Erreur createClient:', error);
      return null;
    }
  }

  async updateClient(id: number, client: Partial<Client>): Promise<Client | null> {
    try {
      return await lastValueFrom(
        this.http.put<Client>(`${this.apiUrl}/clients/${id}`, client, {
          headers: this.getAuthHeaders()
        })
      );
    } catch (error) {
      console.error('Erreur updateClient:', error);
      return null;
    }
  }

  async deleteClient(id: number): Promise<boolean> {
    try {
      await lastValueFrom(
        this.http.delete(`${this.apiUrl}/clients/${id}`, {
          headers: this.getAuthHeaders()
        })
      );
      return true;
    } catch (error) {
      console.error('Erreur deleteClient:', error);
      return false;
    }
  }


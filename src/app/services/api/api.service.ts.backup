      return [];
    }
  }

  async createFacture(facture: Partial<Facture>): Promise<Facture | null> {
    try {
      return await lastValueFrom(
        this.http.post<Facture>(`${this.apiUrl}/factures`, facture, {
          headers: this.getAuthHeaders()
        })
      );
    } catch (error) {
      console.error('Erreur createFacture:', error);
      return null;
    }
  }

  // ==================== DEVIS ====================
  
  async getDevis(): Promise<Devis[]> {
    try {
      return await lastValueFrom(
        this.http.get<Devis[]>(`${this.apiUrl}/devis`, {
